<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.github.stazxr.zblog.mapper.CategoryMapper">
    <select id="selectCategoryList" resultType="com.github.stazxr.zblog.domain.vo.CategoryVo">
        SELECT
            c.ID, c.PID, c.NAME, c.SLUG, c.IMAGE_URL, c.DESCRIPTION,
            c.ALLOW_INDEX, c.ENABLED, c.VISIBLE, c.SORT, c.CREATE_TIME, c.UPDATE_TIME, COUNT(a.ID) AS ARTICLE_COUNT
        FROM category c
        LEFT JOIN category c2 ON c2.PID = c.ID
        LEFT JOIN article a ON a.DELETED = 0 AND (
            a.CATEGORY_ID = c.ID OR a.CATEGORY_ID = c2.ID
        )
        <where>
            <if test="name != null and name != ''">
                <bind name="nameBind" value="'%' + name + '%'"/>
                AND c.NAME LIKE #{nameBind}
            </if>
            <if test="slug != null and slug != ''">
                <bind name="slugBind" value="'%' + slug + '%'"/>
                AND c.SLUG LIKE #{slugBind}
            </if>
            <if test="pid != null">
                AND c.PID = #{pid}
            </if>
            <if test="allowIndex != null">
                AND c.ALLOW_INDEX = #{allowIndex}
            </if>
            <if test="visible != null">
                AND c.VISIBLE = #{visible}
            </if>
            <if test="enabled != null">
                AND c.ENABLED = #{enabled}
            </if>
        </where>
        GROUP BY c.ID
        ORDER BY c.SORT
    </select>

    <select id="selectCategoryDetail" resultType="com.github.stazxr.zblog.domain.vo.CategoryVo">
        SELECT
            c.ID, c.PID, c.NAME, c.SLUG, c.IMAGE_URL, c.DESCRIPTION,
            c.SEO_TITLE, c.SEO_KEYWORDS, c.SEO_DESCRIPTION, c.ALLOW_INDEX,
            c.SORT, c.ENABLED, c.VISIBLE, c.CREATE_TIME, c.UPDATE_TIME,
            (SELECT cp.NAME FROM category cp WHERE cp.ID = c.PID) AS PARENT_NAME,
            (SELECT COUNT(1) FROM category c2 WHERE c2.PID = c.ID) AS subCount,
            (SELECT u.USERNAME FROM user u WHERE u.ID = c.CREATE_USER) AS CREATE_USERNAME,
            (SELECT u.USERNAME FROM user u WHERE u.ID = c.UPDATE_USER) AS UPDATE_USERNAME,
            IF(
                c.PID IS NULL,
                (
                    SELECT COUNT(1) FROM article a WHERE a.DELETED = 0 AND a.CATEGORY_ID IN (
                        SELECT c1.ID FROM category c1 WHERE c1.PID = c.ID
                    )
                ),
                (
                    SELECT COUNT(1) FROM article a WHERE a.DELETED = 0 AND a.CATEGORY_ID = c.ID
                )
            ) AS ARTICLE_COUNT
        FROM category c
        WHERE c.ID = #{categoryId}
    </select>


